NODE_ENV=test
APP_PORT=3001
API_PREFIX=api
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=api_test
DATABASE_USER=user
DATABASE_PASSWORD=secret
DATABASE_URL=postgresql://user:secret@localhost:5433/api_test

# Auth
AUTH_JWT_SECRET=placeholder-jwt-secret
AUTH_REFRESH_SECRET=placeholder-refresh-secret
AUTH_COOKIE_SECRET=placeholder-cookie-secret
AUTH_JWT_EXPIRES_IN=15m
AUTH_REFRESH_EXPIRES_IN=7d
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_DURATION=15m
AUTH_OTP_EXPIRES_IN=10m
AUTH_SESSION_EXPIRES_IN=1h
AUTH_CHANGE_PASSWORD_TOKEN_EXPIRES_IN=15m
AUTH_RESEND_VERIFICATION_MAX_REQUESTS=3
AUTH_RESEND_VERIFICATION_WINDOW=1h
AUTH_MIN_AGE_REGISTER=13

# Mail
RESEND_API_KEY=placeholder-key
MAIL_FROM="Test <no-reply@test.com>"
MAIL_REPLY_TO="support@test.com"

# Storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=./uploads-test
MAX_FILE_SIZE=5242880
ALLOWED_MIME_TYPES=image/*,video/*,application/pdf
PRESIGNED_URL_EXPIRY=3600
