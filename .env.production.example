# ===========================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy these variables to Vercel Dashboard
# ===========================================

# App
APP_PORT=3000
API_PREFIX=api
NODE_ENV=production
APP_URL=https://your-domain.vercel.app
ALLOWED_ORIGINS=https://your-frontend.com

# Database (use connection string or individual variables)
DATABASE_URL=postgresql://user:password@host:5432/database
# OR individual variables (if DATABASE_URL not used)
DATABASE_HOST=your-db-host
DATABASE_PORT=5432
DATABASE_NAME=your-db-name
DATABASE_USER=your-db-user
DATABASE_PASSWORD=your-db-password

# Auth - Generate strong secrets!
AUTH_JWT_SECRET=your-super-secret-jwt-key-change-this
AUTH_JWT_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=your-super-secret-refresh-key-change-this
AUTH_REFRESH_EXPIRES_IN=7d
AUTH_COOKIE_SECRET=your-cookie-secret-key-change-this
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_DURATION=15m
AUTH_OTP_EXPIRES_IN=10m
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_SESSION_EXPIRES_IN=1h
AUTH_RESEND_VERIFICATION_MAX_REQUESTS=3
AUTH_RESEND_VERIFICATION_WINDOW=1h
AUTH_PASSWORD_RESET_REQUEST_MAX_REQUESTS=3
AUTH_PASSWORD_RESET_REQUEST_WINDOW=1h
AUTH_MIN_AGE_REGISTER=13

# Mail (Resend)
RESEND_API_KEY=re_your_resend_api_key
MAIL_FROM="Help <no-reply@yourdomain.com>"
MAIL_REPLY_TO="support@yourdomain.com"

# Storage - Use S3/R2 in production (local storage doesn't work well on serverless)
STORAGE_PROVIDER=s3
STORAGE_BUCKET=your-bucket-name
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
# Optional for R2 or custom endpoints
STORAGE_ENDPOINT=
# Public URL for accessing files
STORAGE_PUBLIC_URL=https://your-cdn-url.com

# File upload limits
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/*,video/*,application/pdf
PRESIGNED_URL_EXPIRY=3600
