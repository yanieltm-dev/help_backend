# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
APP_NAME=Help
APP_PORT=3000
API_PREFIX=api
NODE_ENV=development
APP_URL=http://api.example.com
ALLOWED_ORIGINS=http://localhost:8100,http://localhost:8200

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=api
DATABASE_USER=user
DATABASE_PASSWORD=secret

# ===========================================
# AUTH CONFIGURATION
# ===========================================
AUTH_JWT_SECRET=your-secret-key
AUTH_JWT_EXPIRES_IN=15m
AUTH_REFRESH_SECRET=your-refresh-secret
AUTH_REFRESH_EXPIRES_IN=7d
AUTH_COOKIE_SECRET=your-cookie-secret
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_DURATION=15m
AUTH_OTP_EXPIRES_IN=10m
AUTH_OTP_MAX_ATTEMPTS=5
AUTH_SESSION_EXPIRES_IN=1h
AUTH_RESEND_VERIFICATION_MAX_REQUESTS=3
AUTH_RESEND_VERIFICATION_WINDOW=1h
AUTH_PASSWORD_RESET_REQUEST_MAX_REQUESTS=3
AUTH_PASSWORD_RESET_REQUEST_WINDOW=1h

# Registration
AUTH_MIN_AGE_REGISTER=13

# ===========================================
# MAIL CONFIGURATION
# ===========================================
RESEND_API_KEY=your-resend-api-key
MAIL_FROM="Help <no-reply@example.com>"
MAIL_REPLY_TO="support@example.com"

# ===========================================
# STORAGE / MEDIA CONFIGURATION
# ===========================================
# Options: local, s3, s3-presigned
STORAGE_PROVIDER=local
# For S3/R2
STORAGE_BUCKET=your-bucket-name
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
# Only for R2 or custom S3-compatible (Minio)
STORAGE_ENDPOINT=http://localhost:9000
# Base public URL for the bucket (e.g., https://pub-xxx.r2.dev or Cloudfront)
STORAGE_PUBLIC_URL=
# Only for local provider
STORAGE_LOCAL_PATH=./uploads
# Limits and validation
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/*,video/*,application/pdf
PRESIGNED_URL_EXPIRY=3600
